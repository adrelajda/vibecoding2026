# ============================================================
#  Šablona konfigurace – zkopírujte do .env a vyplňte hodnoty
#  cp .env.example .env
# ============================================================

# Anthropic API klíč (získáte na https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# E-mailový účet
EMAIL_ADDRESS=vas@email.cz
EMAIL_PASSWORD=vase-heslo

# IMAP (příchozí pošta)
IMAP_HOST=imap.dianasiswartonova.cz
IMAP_PORT=993

# SMTP (odchozí pošta)
SMTP_HOST=smtp.dianasiswartonova.cz
SMTP_PORT=465

# Složka pro koncepty odpovědí
DRAFTS_FOLDER=Drafts

# IMAP dotaz (UNSEEN = nepřečtené, ALL = vše)
EMAIL_QUERY=UNSEEN
